{
  "name": "a-long-day-in-hell",
  "version": "0.3.1",
  "type": "module",
  "scripts": {
    "test": "node --test 'test/!(browser|dom-*|*-dom|keybindings|spawn|godmode-panel|godmode-tabs).test.js'",
    "test:dom": "node --test 'test/dom-*.test.js' 'test/*-dom.test.js' 'test/keybindings.test.js' 'test/spawn.test.js' 'test/godmode-panel.test.js' 'test/godmode-tabs.test.js'",
    "test:slow": "node --test 'test/slow/*.test.js'",
    "test:all": "node --test 'test/!(browser).test.js' 'test/slow/*.test.js'",
    "test:browser": "bash test/browser.sh",
    "test:e2e": "npx playwright test",
    "build": "bash build.sh"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "esbuild": "^0.27.3",
    "jsdom": "^28.1.0",
    "playwright": "^1.58.2",
    "serve": "^14.2.6",
    "typescript": "^5.9.3"
  }
}
